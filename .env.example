# ── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
EVENT_NAME=Pop DeKegg's Tavern
SMS_MESSAGE=Here's your photo from {EVENT_NAME}! 🎉

# ── Booth password (shown to guests on the homepage) ────────────────────────
# Leave blank to disable the password gate (open booth)
BOOTH_PASSWORD=

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-123

# ── Gallery ─────────────────────────────────────────────────────────────────
GALLERY_ENABLED=true
GALLERY_SLUG=jakes-party

# ── Public URL (required for Twilio MMS) ────────────────────────────────────
# Must be publicly accessible from the internet.
# In production: set to your Railway/Render URL
# In local dev: use ngrok → https://xxxxx.ngrok.io
PUBLIC_URL=http://localhost:3000
